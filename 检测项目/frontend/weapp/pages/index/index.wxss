.container {
  padding: 0;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  color: white;
  padding: 30rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  background: white;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.card {
  background: white;
  margin: 0 20rpx 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

#chart {
  width: 100%;
  height: 400rpx;
}
